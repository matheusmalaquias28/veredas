# Sanity (público — usado no browser e no build)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Opcional: URL canónica (ex. https://veredas-alpha.vercel.app).
# Na Vercel, se omitir, usa-se automaticamente https://$VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Apenas servidor (preview/drafts) — definir na Vercel como secret, não commitar
# SANITY_API_TOKEN=

# Resend — envio dos formulários (definir em .env.local e na Vercel; nunca commitar a chave)
# RESEND_API_KEY=
#
# Vercel (sandbox + produção): Project → Settings → Environment Variables
# - Crie RESEND_API_KEY com o mesmo valor da chave no Resend.
# - Marque os ambientes: Production E Preview (e Development se quiser).
#   Se só "Development" estiver marcado, veredas-alpha.vercel.app e veredas.art NÃO recebem a chave.
#
# Opcional: remetente com domínio verificado no Resend (recomendado em produção):
# RESEND_FROM_EMAIL=Veredas Site <noreply@veredas.art>
# Sem isso, usa onboarding@resend.dev — o Resend pode limitar destinatários até o domínio estar verificado.
# Ver: https://resend.com/docs/dashboard/domains/introduction
