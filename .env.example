# Sanity (público — usado no browser e no build)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Opcional: URL canónica (ex. https://veredas-alpha.vercel.app).
# Na Vercel, se omitir, usa-se automaticamente https://$VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Apenas servidor (preview/drafts) — definir na Vercel como secret, não commitar
# SANITY_API_TOKEN=

# Resend — envio dos formulários (definir em .env.local e na Vercel; nunca commitar a chave)
# RESEND_API_KEY=
# Opcional: remetente verificado no Resend (ex.: Veredas Site <noreply@veredas.art>)
# Se omitir, usa o remetente de teste do Resend (limitações no plano free).
# RESEND_FROM_EMAIL=
